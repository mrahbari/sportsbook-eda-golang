# Copy to `.env` and adjust if needed. Docker Compose below uses inline env; this file documents local `go run` usage.

# MySQL DSN (go-sql-driver/mysql format)
# Example (Docker Compose host ports): sportsbook:sportsbook@tcp(127.0.0.1:3306)/sportsbook?parseTime=true
MYSQL_DSN=sportsbook:sportsbook@tcp(127.0.0.1:3306)/sportsbook?parseTime=true

# Optional: Dedicated MySQL user for CDC (requires REPLICATION SLAVE/CLIENT privileges).
# If empty, defaults to MYSQL_DSN.
# Example: root:rootsecret@tcp(127.0.0.1:3306)/sportsbook?parseTime=true
MYSQL_CDC_DSN=

# RabbitMQ AMQP URL
# Example: amqp://guest:guest@127.0.0.1:5672/
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/

# Redis address (odds-service cache)
REDIS_ADDR=127.0.0.1:6379

# HTTP listen address (set per process: gateway :8080, bet-service :8081, odds :8082, settlement :8083)
HTTP_ADDR=:8080

# Outbox Relay strategy: 0 = polling (default), 1 = CDC (MySQL Binlog listener)
USE_CDC=0

# If using CDC, should the relay update outbox_events.published_at in MySQL?
# 1 = yes (default), 0 = no (maximum speed)
CDC_WRITE_PUBLISHED_AT=1

# Set to 1 on bet-service to expose POST /dev/publish-test-bet-placed (RabbitMQ smoke test)
DEV_MODE=0

# Optional: expvar metrics listener (e.g. gateway METRICS_ADDR=:9090)
METRICS_ADDR=

# Service Discovery (for api-gateway or direct service-to-service calls)
BET_SERVICE_URL=http://127.0.0.1:8081
ODDS_SERVICE_URL=http://127.0.0.1:8082
SETTLEMENT_SERVICE_URL=http://127.0.0.1:8083

# Note: SQL migrations live under internal/migrate/sql/ and are embedded in the binary.
