		{
			"name": "Bets",
			"item": [
				{
					"name": "Place Bet (Success - User 1)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"last_bet_id\", jsonData.bet_id);",
									"pm.environment.set(\"correlation_id\", jsonData.correlation_id);",
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Request-Id",
								"value": "{{$guid}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"user_id\": \"00000000-0000-0000-0000-000000000001\",\n    \"stake_amount\": \"10.50\",\n    \"currency\": \"USD\",\n    \"selection_id\": \"sel_demo_1\",\n    \"market_id\": \"mkt_demo_1\",\n    \"odds\": 1.95,\n    \"odds_version\": 42\n}"
						},
						"url": {
							"raw": "http://localhost:8080/bets",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8080",
							"path": [
								"bets"
							]
						}
					},
					"response": []
				},
